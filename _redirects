# 작품 상세 슬러그 URL → title.html (200 = rewrite, URL 유지)
# 형식: /title/{작품명}-{시즌}{제작년도}{tmdb_id}
# 예시: /title/원더풀스-12026259837
/title/* /title.html 200

# 구 URL 하위호환 (쿼리스트링 있는 구버전 링크가 들어올 경우)
# 브라우저에서 직접 ?tmdb_id= 형태로 접근하면 title.html이 자동 처리
